#!/usr/bin/env bash

# This script only runs on Linux x64 or ARM64.

set -e -o pipefail

. "$(dirname "$0")/tools/common.sh"


#
# Rename conflicting files on case-insensitive file systems.
#

#
# Rename conflicting filenames in include directives.
#
function rename_includes()
{
	if [ -n "$2" ]; then
		local pattern=""
		for name in $2; do
			pattern="${pattern}${pattern:+\\|}${name}"
		done
		find "$1" -type f -print0 | while IFS= read -r -d '' file; do
			sed -i -b -e "s@\(#include\s*<linux/\(${pattern}\)\)\(\.h>\)@\1_1\3@g" "$file"
			if [ $? != 0 ]; then return 1; fi
		done
	fi
}

#
# Rename conflicting files.
#
function rename_files_windows()
{
	local rename_file_list="\
		netfilter/xt_connmark \
		netfilter/xt_dscp \
		netfilter/xt_mark \
		netfilter/xt_rateest \
		netfilter/xt_tcpmss \
		netfilter_ipv4/ipt_ecn \
		netfilter_ipv4/ipt_ttl \
		netfilter_ipv6/ip6t_hl"

	local renamed_files=""
	local root_dir="${1}/sysroot/usr/include/linux"
	find "$root_dir" -exec chmod +w {} \;
	for name in $rename_file_list ;	do
		local ext=".h"
		if [ -f "${root_dir}/${name}${ext}" ]; then
			echo "Renaming \"${root_dir}/${name}${ext}\" to \"${name}_1${ext}\""
			mv "${root_dir}/${name}${ext}" "${root_dir}/${name}_1${ext}"
			if [ $? != 0 ]; then return 1; fi
			renamed_files="${renamed_files} ${name}"
		fi
	done
	rename_includes "$root_dir" "${renamed_files}"
	if [ $? != 0 ]; then return 1; fi
	find "$root_dir" -exec chmod a-w {} \;
}


function is_linux_host()
{
	if [[ $1 =~ mingw ]]; then
		return 1	# false
	else
		return 0	# true
	fi
}


function install_packages()
{
	local MODULES="$1"
	local HOST="$2"

	local packages="wget xz-utils"
	local llvm_packages="\
		build-essential \
		ca-certificates \
		cmake \
		libz-dev \
		ninja-build \
		python3 \
	"
	for module in $MODULES; do
		case $module in
			llvm)
				packages="${packages} ${llvm_packages}"
				;;
			sysroot)
				packages="${packages} \
					binfmt-support \
					debootstrap \
					qemu-user-binfmt \
				"
				;;
			*)	# Targets
				packages="${packages} \
					${llvm_packages} \
					patch"
				if ! is_linux_host "$HOST"; then
					packages="${packages} \
						7zip \
					"
				fi
				;;
		esac
	done

	sudo apt-get update
	sudo apt-get install -y --no-install-recommends $packages
}


function install_build_compiler()
{
	local MODULES="$1"
	local HOST="$2"

	local llvm_version
	llvm_version="$(get_llvm_version)"

	local install_needed=false
	for module in $MODULES; do
		case $module in
			sysroot) ;;
			llvm)
				install_needed=false
				if is_linux_host "$HOST"; then
					install_needed=true
				fi
				;;
			*-musl*) install_needed=true ;;
		esac
	done

	if ! $install_needed || \
		[[ $(clang --version 2>/dev/null) =~ clang\ version\ ${llvm_version} ]]; then
		return 0
	fi

	local build
	build="$(get_build_machine_type)"
	local llvm_name
	local llvm_sha256
	case $build in
		linux-x64)
			llvm_name="LLVM-${LLVM_VER}-Linux-X64"
			llvm_sha256=$LLVM_X64_SHA256
			;;
		linux-arm64)
			llvm_name="LLVM-${LLVM_VER}-Linux-ARM64"
			llvm_sha256=$LLVM_ARM64_SHA256
			;;
		*)
			echo "Build machine not supported (${build})."
			return 1
			;;
	esac
	sudo rm -rf build-compiler
	mkdir build-compiler
	pushd build-compiler

	local llvm_bin_path=""

	local tarname="llvm-clang-${build}-${llvm_version}.tar.xz"
	if [ ! -f "../${tarname}" ]; then
		url="${CROSS_CLANG_URL}/clang-cross/releases/download/${CROSS_CLANG_LATEST}/${tarname}"
		if wget -nv -nc -T 120 --tries=20 $options "$url" 2>/dev/null; then
			show_progress_message "Downloading llvm-clang-cross compiler for ${build}"
			echo "${url}"
			mv "$tarname" ..
		fi
	fi
	if [ -f "../${tarname}" ]; then
		tar -xf "../${tarname}"
		llvm_bin_path="$(pwd)/clang-cross/bin"
	fi

	if [ -z "$llvm_bin_path" ]; then
		local tarname="${llvm_name}.tar.xz"
		if [ ! -f "../${tarname}" ]; then
			show_progress_message "Downloading LLVM ${LLVM_VER} release"
			local url="${LLVM_URL}/llvm-project/releases/download/llvmorg-${LLVM_VER}/${tarname}"
			local options=""
			if tty -s; then
				options="--show-progress"
			fi
			wget -nv -nc -T 120 --tries=20 $options "$url"
			check_sha256 "$tarname" "$llvm_sha256"
			mv "$tarname" ..
		fi
		show_progress_message "Extracting LLVM"
		tar -xf "../${tarname}"
		mv "$llvm_name" "llvm-${LLVM_VER}"
		llvm_bin_path="$(pwd)/llvm-${LLVM_VER}/bin"
	fi

	export PATH="${llvm_bin_path}:$PATH"
	popd
}


function build_sysroot()
{
	local HOST="$1"
	local HOST_NAME
	HOST_NAME="$(sed 's/-unknown//g' <<< "$HOST")"
	local arch_name
	local suite

	case $HOST_NAME in
		aarch64-linux-*)
			arch_name="arm64"
			suite="stable"
			;;
		riscv64-linux-*)
			arch_name="riscv64"
			suite="unstable"
			;;
		x86_64-linux-*)
			arch_name="amd64"
			suite="stable"
			;;
		*)
			echo "Host not supported (${HOST})."
			return 1
			;;
	esac
	local SYSROOT_NAME="sysroot-${HOST_NAME}"

	sudo rm -rf build
	mkdir build
	pushd build

	show_progress_message "Downloading sysroot for ${arch_name}"

	sudo rm -rf "$SYSROOT_NAME"
	sudo debootstrap --arch=${arch_name} --variant=minbase \
		--include=build-essential,symlinks ${suite} "$SYSROOT_NAME"
	sudo chroot "$SYSROOT_NAME" symlinks -cr .

	show_progress_message "Creating \"sysroot-${HOST}.tar.xz\""

	sudo tar -cJvf "../sysroot-${HOST}.tar.xz" "$SYSROOT_NAME"
	popd
	sudo rm -rf build
}


function set_cmake_var()
{
	printf 'set(CMAKE_%s "%s")\n' "$1" "$2" >> "toolchain.cmake"
}


function build_llvm()
{
	local HOST="$1"
	local DEFAULT_TARGET="$2"

	local HOST_NAME
	HOST_NAME="$(sed 's/-unknown//g' <<< "$HOST")"
	local SYSROOT_NAME=""
	local CC_FLAGS=""

	local llvm_version
	llvm_version="$(get_llvm_version)"

	sudo rm -rf build-llvm
	mkdir build-llvm
	pushd build-llvm

	rm -f toolchain.cmake
	set_cmake_var SYSTEM_PROCESSOR "${HOST%%-*}"

	if is_linux_host "$HOST"; then
		set_cmake_var SYSTEM_NAME Linux
		SYSROOT_NAME="sysroot-${HOST_NAME}"
		set_cmake_var SYSROOT "$(pwd)/${SYSROOT_NAME}"

		sudo rm -rf "${SYSROOT_NAME}"
		sudo tar -xf "../sysroot-${HOST}.tar.xz"
		if [ ! -d "${SYSROOT_NAME}/usr/lib/${HOST_NAME}" ]; then
			echo "[ERROR] Host ${HOST_NAME} not found in sysroot usr/lib." >&2
			return 1
		fi

		set_cmake_var C_COMPILER clang
		set_cmake_var CXX_COMPILER clang++
		set_cmake_var STRIP "$(get_latest_exec_path llvm-strip)"
	else
		set_cmake_var SYSTEM_NAME Windows
		SYSROOT_NAME="llvm-mingw"
		local build
		build="$(get_build_machine_type)"
		local name
		local sha256
		case $build in
			linux-x64)
				name="llvm-mingw-${LLVM_MINGW_VER}-msvcrt-ubuntu-${LLVM_MINGW_UBNT_VER}-x86_64"
				sha256=$LLVM_MINGW_X64_SHA256
				;;
			linux-arm64)
				name="llvm-mingw-${LLVM_MINGW_VER}-ucrt-ubuntu-${LLVM_MINGW_UBNT_VER}-aarch64"
				sha256=$LLVM_MINGW_ARM64_SHA256
				;;
			*)
				echo "Build machine not supported (${build})."
				return 1
				;;
		esac

		show_progress_message "Downloading LLVM-MinGW ${LLVM_MINGW_VER} release"

		local tarname="${name}.tar.xz"
		local url="${LLVM_MINGW_URL}/llvm-mingw/releases/download/${LLVM_MINGW_VER}/${tarname}"
		wget -nv -nc -T 120 --tries=20 "$url"
		check_sha256 "$tarname" "$sha256"
		tar -xf "$tarname"
		mv "$name" "${SYSROOT_NAME}"
		export PATH="$(pwd)/${SYSROOT_NAME}/bin:$PATH"
		if [ ! -d "${SYSROOT_NAME}/${HOST_NAME}" ]; then
			echo "[ERROR] Host ${HOST_NAME} not supported by llvm-mingw." >&2
			return 1
		fi

		show_progress_message "Configuring LLVM ${llvm_version}"

		set_cmake_var FIND_ROOT_PATH "$(pwd)/${SYSROOT_NAME}/${HOST_NAME}"
		set_cmake_var GET_RUNTIME_DEPENDENCIES_PLATFORM "windows+pe"
		set_cmake_var C_COMPILER "${HOST_NAME}-clang"
		set_cmake_var CXX_COMPILER "${HOST_NAME}-clang++"
		set_cmake_var STRIP "${HOST_NAME}-strip"

		# Dynamic library for host
		mkdir -p "clang-cross/bin"
		host_lib="${SYSROOT_NAME}/${HOST_NAME}/bin"
		for f in "${host_lib}"/lib*.dll ; do
			if [ -f "$f" ]; then
				echo "Copying \"$f\" to \"clang-cross/bin/\""
				cp "$f" "clang-cross/bin/"
			fi
		done
	fi

	cat - <<-EOF >> toolchain.cmake
		set(CMAKE_C_COMPILER_TARGET $HOST_NAME)
		set(CMAKE_CXX_COMPILER_TARGET $HOST_NAME)
		set(CMAKE_C_FLAGS_INIT "$CC_FLAGS")
		set(CMAKE_CXX_FLAGS_INIT "$CC_FLAGS")
		set(CMAKE_LINKER_TYPE LLD)
		set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
		set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
		set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
		set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
	EOF

	echo -e "\n*** CMAKE toolchain file ***\n"
	cat toolchain.cmake

	local LLVM_TARGETS="AArch64;ARM;LoongArch;Mips;PowerPC;RISCV;SystemZ;X86"
	local options=""
	if [ -n "$DEFAULT_TARGET" ]; then
		options="${options} -DLLVM_DEFAULT_TARGET_TRIPLE=${DEFAULT_TARGET}"
	fi

	cmake -G Ninja -S ../llvm/llvm $options \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_TOOLCHAIN_FILE="$(pwd)/toolchain.cmake" \
		-DCMAKE_INSTALL_PREFIX="$(pwd)/clang-cross" \
		-DLLVM_ENABLE_PROJECTS="clang;lld" \
		-DLLVM_HOST_TRIPLE=${HOST_NAME} \
		-DLLVM_TARGETS_TO_BUILD="${LLVM_TARGETS}" \
		-DCLANG_LINK_CLANG_DYLIB=ON \
		-DLLVM_LINK_LLVM_DYLIB=ON \
		-DLLVM_INSTALL_TOOLCHAIN_ONLY=ON \
		-DENABLE_LINKER_BUILD_ID=ON \
		-DCLANG_DEFAULT_LINKER=lld \
		-DCLANG_DEFAULT_PIE_ON_LINUX=ON \
		-DLLVM_ENABLE_EH=ON \
		-DLLVM_ENABLE_RTTI=ON \
		-DLLVM_ENABLE_ZLIB=ON

	show_progress_message "Building LLVM ${llvm_version}"

	ninja install/strip

	sudo chown -R root:0 clang-cross

	if [ -n "$DEFAULT_TARGET" ]; then
		local name="llvm-clang-${HOST}-${llvm_version}_${DEFAULT_TARGET}.tar.xz"
	else
		local name="llvm-clang-${HOST}-${llvm_version}.tar.xz"
	fi

	show_progress_message "Creating \"${name}\""

	tar -cJvf "../${name}" clang-cross
	popd
	sudo rm -rf build-llvm

	echo -e "\nThe compiler alone, without the C library, is in"
	echo -e "${name} .\n"
}


function build_target()
{
	local HOST="$1"
	local TARGET="$2"
	local DEFAULT_TARGET="$3"
	local SCRIPTS="$(pwd)/scripts/tools"

	local llvm_version
	llvm_version="$(get_llvm_version)"

	sudo rm -rf build
	mkdir build
	pushd build

	if [ -n "$DEFAULT_TARGET" ]; then
		local name="../llvm-clang-${HOST}-${llvm_version}_${DEFAULT_TARGET}.tar.xz"
	else
		local name="../llvm-clang-${HOST}-${llvm_version}.tar.xz"
	fi
	tar -xf "$name"

	"${SCRIPTS}/build_target.sh" "$TARGET" "" "$DEFAULT_TARGET"

	if ! is_linux_host "$HOST"; then
		rename_files_windows "clang-cross/${TARGET}"
	fi

	local host_name
	host_name="$(sed 's/-unknown//g' <<< "$HOST")"
	case $host_name in
		aarch64-linux-gnu)
			host_name="linux-arm64" ;;
		aarch64-w64-mingw32)
			host_name="win-arm64" ;;
		riscv64-linux-gnu)
			host_name="linux-riscv64" ;;
		x86_64-linux-gnu)
			host_name="linux-x64" ;;
		x86_64-w64-mingw32)
			host_name="win-x64" ;;
	esac

	# Tarballs
	sudo rm -rf ${TARGET}
	mv clang-cross ${TARGET}
	sudo chown -R root:0 ${TARGET}

	if is_linux_host "$HOST"; then
		local name="clang-${host_name}_${TARGET}.tar.xz"
		show_progress_message "Creating \"${name}\""
		tar -cJvf "../${name}" "${TARGET}"
	else
		local name="clang-${host_name}_${TARGET}.7z"
		show_progress_message "Creating \"${name}\""
		7z a -mx9 "../${name}" "${TARGET}"
	fi
	local hash
	hash="$(sha256sum "../${name}" | awk '{ print $1 }')"
	printf '%s *%s\n' "$hash" "$name" > "../${name}.sha256"
	popd
	sudo rm -rf build

	echo -e "\nThe complete toolchain is in"
	echo -e "${name} .\n"
}


HOST=$1
TARGET=$2
DEFAULT_TARGET=$3

if [ -z "$HOST" ]; then
	echo "[ERROR] Host is missing." >&2
	exit 1
fi

if [ -z "$TARGET" ]; then
	echo "[ERROR] Target is missing." >&2
	exit 1
fi

if [[ $TARGET != "sysroot" && $TARGET != "llvm" && \
		! -f "targets/${TARGET}/config" ]]; then
	echo "[ERROR] Target not supported (${TARGET})." >&2
	exit 1
fi

llvm_version="$(get_llvm_version)"

if [ -n "$DEFAULT_TARGET" ]; then
	llvm_tarname="llvm-clang-${HOST}-${llvm_version}_${DEFAULT_TARGET}.tar.xz"
else
	llvm_tarname="llvm-clang-${HOST}-${llvm_version}.tar.xz"
	if [ ! -f "$llvm_tarname" ]; then
		for name in llvm-clang-${HOST}-${llvm_version}_*.tar.xz; do
			if [[ -f $name && $name =~ ^llvm-clang-${HOST}-${llvm_version}_(.+)\.tar\.xz$ ]]; then
				DEFAULT_TARGET=${BASH_REMATCH[1]}
				llvm_tarname="llvm-clang-${HOST}-${llvm_version}_${DEFAULT_TARGET}.tar.xz"
				break
			fi
		done
		if [[ -z $DEFAULT_TARGET && $TARGET != "llvm" ]]; then
			DEFAULT_TARGET=$TARGET
		fi
	fi
fi

modules=""
if is_linux_host "$HOST" && [[ ! -f "sysroot-${HOST}.tar.xz" && \
		! -f "$llvm_tarname" ]]; then
	modules="${modules} sysroot"
fi
if [[ $TARGET != "sysroot" && ! -f "$llvm_tarname" ]]; then
	url="${CROSS_CLANG_URL}/clang-cross/releases/download/${CROSS_CLANG_VER}/${llvm_tarname}"
	if ! wget -nv -nc -T 120 --tries=20 "$url" 2>/dev/null; then
		modules="${modules} llvm"
	fi
fi
if [[ $TARGET != "sysroot" && $TARGET != "llvm" ]]; then
	modules="${modules} ${TARGET}"
fi

install_packages "$modules" "$HOST"
install_build_compiler "$modules" "$HOST"

for module in $modules; do
	case $module in
		sysroot)  build_sysroot "$HOST" ;;
		llvm)     build_llvm "$HOST" "$DEFAULT_TARGET" ;;
		*)        build_target "$HOST" "$TARGET" "$DEFAULT_TARGET" ;;
	esac
done

rm -rf build-compiler

echo -e "\nDone.\n"
